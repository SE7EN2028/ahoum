# ----------------------------------------------------------------------------
# Ahoum — environment template.
# Copy to .env, fill in the values, then: docker compose up --build
#
# Docker Compose reads this file for ${VAR} interpolation and passes it into the
# backend container. Frontend VITE_* values are baked into the static bundle at
# BUILD time, so rebuild the frontend after changing them.
# Do NOT commit your real .env — it is gitignored.
# ----------------------------------------------------------------------------

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=ahoum                       # database name
POSTGRES_USER=ahoum                     # database user
POSTGRES_PASSWORD=change-me             # database password (change for real use)
POSTGRES_HOST=db                        # host = the compose service name
POSTGRES_PORT=5432                      # database port

# --- Django -------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string   # Django crypto secret
DJANGO_DEBUG=1                          # 1 = development (enables dev login), 0 = production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend      # hosts Django will serve
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5174   # browser origins allowed to call the API
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:5174   # origins trusted for CSRF

# --- JWT ----------------------------------------------------------------------
JWT_ACCESS_MIN=15                       # access token lifetime (minutes)
JWT_REFRESH_DAYS=7                      # refresh token lifetime (days)

# --- Dev superuser (auto-created on first boot for /admin/) -------------------
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@ahoum.local
DJANGO_SUPERUSER_PASSWORD=admin12345    # change for real use

# --- Google OAuth -------------------------------------------------------------
# From Google Cloud Console → APIs & Services → Credentials → OAuth client ID.
# Leave blank to use the development login fallback (no Google required).
GOOGLE_CLIENT_ID=                       # e.g. 1234567890-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=                   # backend only; never exposed to the browser
OAUTH_REDIRECT_URI=http://localhost/auth/callback   # must match the URI registered in Google Cloud

# --- Frontend (build-time; baked into the static bundle) ----------------------
VITE_API_BASE=/api                      # API base path (the Nginx proxy routes it)
VITE_GOOGLE_CLIENT_ID=                  # public OAuth client id — SAME value as GOOGLE_CLIENT_ID

# --- Stripe (test mode; powers paid-session checkout) -------------------------
# From the Stripe Dashboard (test mode). Leave blank to disable paid bookings.
STRIPE_SECRET_KEY=                      # sk_test_... (backend only)
STRIPE_WEBHOOK_SECRET=                  # whsec_... from `stripe listen` or the webhook endpoint
STRIPE_CURRENCY=inr                     # ISO currency for checkout (must match your Stripe account)
FRONTEND_BASE_URL=http://localhost      # where Stripe returns the user after checkout

# --- Bonus (optional; uncomment when enabling these features) -----------------
# MINIO_ROOT_USER=ahoum
# MINIO_ROOT_PASSWORD=change-me
# MINIO_BUCKET=ahoum-media
