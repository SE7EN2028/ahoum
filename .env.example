# Copy to .env, then `docker compose up --build`.
# Compose reads this file for ${VAR} interpolation; backend also loads it via env_file.

# --- PostgreSQL ---
POSTGRES_DB=ahoum
POSTGRES_USER=ahoum
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Django ---
DJANGO_SECRET_KEY=dev-secret-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Origins allowed to call the API in dev (vite dev server, nginx origin)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:5173

# --- JWT ---
JWT_ACCESS_MIN=15
JWT_REFRESH_DAYS=7

# --- Dev superuser (auto-created on boot; admin login + JWT testing) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@ahoum.local
DJANGO_SUPERUSER_PASSWORD=admin12345

# --- Google OAuth (used from Phase 2) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost/auth/callback

# --- Frontend (build-time, baked into the static bundle) ---
VITE_API_BASE=/api
VITE_GOOGLE_CLIENT_ID=

# --- Bonus (later) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# MINIO_ROOT_USER=ahoum
# MINIO_ROOT_PASSWORD=change-me
# MINIO_BUCKET=ahoum-media
